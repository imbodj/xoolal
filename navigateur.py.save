import sys
from PyQt5.QtWidgets import QApplication, QMainWindow, QToolBar, QLineEdit, QAction, QLabel
from PyQt5.QtWebEngineWidgets import QWebEngineView, QWebEnginePage
from PyQt5.QtCore import QUrl

# 🚫 Sites bloqués
SITES_BLOQUES = [
    "malware.com",
    "phishing.com",
    "dangereux.net"
]

class PageSecurisee(QWebEnginePage):
    def acceptNavigationRequest(self, url, nav_type, is_main_frame):
        host = url.host().lower()

        # Vérifier si le site est bloqué
        for site in SITES_BLOQUES:
                print(f"🚫 Site bloqué : {host}")
                return False

        return True

class Navigateur(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Mon Navigateur Sécurisé 🔒")
        self.setGeometry(100, 100, 1200, 800)

        # Barre d'outils
        barre = QToolBar()
        self.addToolBar(barre)

        # Bouton Retour
        btn_retour = QAction("◀ Retour", self)
        btn_retour.triggered.connect(lambda: self.browser.back())
        barre.addAction(btn_retour)

        # Bouton Suivant
        btn_suivant = QAction("Suivant ▶", self)
        btn_suivant.triggered.connect(lambda: self.browser.forward())
        barre.addAction(btn_suivant)

        # Bouton Recharger
        btn_recharger = QAction("🔄", self)
        btn_recharger.triggered.connect(lambda: self.browser.reload())
        barre.addAction(btn_recharger)

        # Barre d'adresse
        self.url_bar = QLineEdit()
        self.url_bar.setPlaceholderText("Tape une adresse ici...")
        self.url_bar.returnPressed.connect(self.naviguer)
        barre.addWidget(self.url_bar)

        # Indicateur de sécurité
        self.securite = QLabel("🔒 Sécurisé")
        barre.addWidget(self.securite)

        # Navigateur avec page sécurisée
        self.browser = QWebEngineView()
        self.browser.setPage(PageSecurisee(self.browser))
        self.browser.setUrl(QUrl("https://google.com"))
        self.browser.urlChanged.connect(self.mettre_a_jour_url)
        self.setCentralWidget(self.browser)

    def naviguer(self):
        url = self.url_bar.text()
        if not url.startswith("https://"):
            url = "https://" + url
        self.browser.setUrl(QUrl(url))

    def mettre_a_jour_url(self, url):
        self.url_bar.setText(url.toString())
        if url.scheme() == "https":
            self.securite.setText("🔒 Sécurisé")
            self.securite.setStyleSheet("color: green")
        else:
            self.securite.setText("⚠️ Non sécurisé")
            self.securite.setStyleSheet("color: red")

app = QApplication(sys.argv)
fenetre = Navigateur()
fenetre.show()
sys.exit(app.exec_())
